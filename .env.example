# Configuración de Café Central (SysCoffee)
# Copia este archivo como `.env.local` para uso local y activa las variables que necesites.

# Habilita las etiquetas de rol [DEBUG] encima de las alternativas en el ChoicePanel (true / false)
VITE_SHOW_DEBUG_ROLES=false

# URL del formulario de Formspree para la evaluación del test
VITE_FORMSPREE_URL=https://formspree.io/f/tu-id-de-formulario
